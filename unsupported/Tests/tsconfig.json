{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "./",
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "Node",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "types": [
      "mod",
      "jest"
    ],
    "paths": {
      "@modsim/*": [
        "../modsim/*"
      ],
      "@besieged/*": [
        "../Besieged/*"
      ]
    },
    "outDir": "dist"
  },
  "ts-node": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}